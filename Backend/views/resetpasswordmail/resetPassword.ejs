<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Reset Password</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 0;
      background: #020617;
      font-family: Arial, sans-serif;
    "
  >
    <table width="100%" cellpadding="0" cellspacing="0" style="padding: 40px 0">
      <tr>
        <td align="center">
          <table
            width="620"
            cellpadding="0"
            cellspacing="0"
            style="
              background: #0f172a;
              border: 1px solid #1e293b;
              border-radius: 20px;
              overflow: hidden;
              box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
            "
          >
            <!-- Header -->
            <tr>
              <td
                style="
                  background: linear-gradient(
                    135deg,
                    #06b6d4,
                    #2563eb,
                    #1e40af
                  );
                  padding: 45px;
                  text-align: center;
                "
              >
                <h1
                  style="
                    margin: 0;
                    color: white;
                    font-size: 30px;
                    font-weight: 700;
                  "
                >
                  AI Career Platform
                </h1>

                <p
                  style="
                    margin-top: 12px;
                    color: rgba(255, 255, 255, 0.85);
                    font-size: 15px;
                  "
                >
                  Secure Password Reset Request
                </p>
              </td>
            </tr>

            <!-- Body -->
            <tr>
              <td style="padding: 45px">
                <h2
                  style="
                    margin-top: 0;
                    color: #f8fafc;
                    font-size: 24px;
                  "
                >
                  Reset Your Password
                </h2>

                <p
                  style="
                    color: #cbd5e1;
                    font-size: 15px;
                    line-height: 1.8;
                  "
                >
                  Hello <strong><%= name %></strong>,
                </p>

                <p
                  style="
                    color: #94a3b8;
                    font-size: 15px;
                    line-height: 1.8;
                  "
                >
                  We received a request to reset the password associated with
                  your account. Click the button below to create a new password.
                </p>

                <!-- Button -->
                <div style="text-align: center; margin: 40px 0">
                  <a
                    href="<%= resetLink %>"
                    style="
                      display: inline-block;
                      padding: 15px 35px;
                      background: linear-gradient(
                        135deg,
                        #06b6d4,
                        #2563eb
                      );
                      color: white;
                      text-decoration: none;
                      border-radius: 12px;
                      font-weight: 700;
                      font-size: 15px;
                    "
                  >
                    Reset Password
                  </a>
                </div>

                <!-- Info Box -->
                <div
                  style="
                    background: rgba(6, 182, 212, 0.08);
                    border: 1px solid rgba(6, 182, 212, 0.25);
                    border-radius: 12px;
                    padding: 16px;
                    margin-bottom: 25px;
                  "
                >
                  <p
                    style="
                      margin: 0;
                      color: #67e8f9;
                      font-size: 14px;
                    "
                  >
                    ⚡ This password reset link will expire in
                    <strong>10 minutes</strong>.
                  </p>
                </div>

                <p
                  style="
                    color: #94a3b8;
                    font-size: 14px;
                    line-height: 1.8;
                  "
                >
                  If you did not request a password reset, you can safely ignore
                  this email. Your account will remain secure.
                </p>

                <!-- Backup Link -->
                <div
                  style="
                    margin-top: 30px;
                    background: #020617;
                    border: 1px solid #1e293b;
                    border-radius: 10px;
                    padding: 14px;
                    word-break: break-all;
                  "
                >
                  <p
                    style="
                      margin: 0 0 8px;
                      color: #94a3b8;
                      font-size: 13px;
                    "
                  >
                    If the button doesn't work, copy and paste this URL:
                  </p>

                  <span
                    style="
                      color: #38bdf8;
                      font-size: 13px;
                    "
                  >
                    <%= resetLink %>
                  </span>
                </div>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td
                style="
                  background: #020617;
                  border-top: 1px solid #1e293b;
                  text-align: center;
                  padding: 25px;
                "
              >
                <p
                  style="
                    margin: 0;
                    color: #64748b;
                    font-size: 13px;
                  "
                >
                  © <%= year %> AI Career Platform. All rights reserved.
                </p>

                <p
                  style="
                    margin-top: 10px;
                    color: #475569;
                    font-size: 12px;
                  "
                >
                  Empowering careers with AI-powered learning and assessment.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>