<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Email Verification</title>
  </head>

  <body
    style="
      margin: 0;
      padding: 40px 20px;
      background: #020617;
      font-family: Arial, sans-serif;
    "
  >
    <div
      style="
        max-width: 650px;
        margin: auto;
        background: #0f172a;
        border: 1px solid #1e293b;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
      "
    >
      <!-- Header -->

      <div
        style="
          background: linear-gradient(
            135deg,
            #0f172a 0%,
            #1e3a8a 50%,
            #2563eb 100%
          );
          padding: 60px 30px;
          text-align: center;
        "
      >
        <h1 style="margin: 0; color: white; font-size: 34px; font-weight: 700">
          AI Career Platform
        </h1>

        <p style="margin-top: 12px; color: #dbeafe; font-size: 15px">
          Secure Email Verification
        </p>
      </div>

      <!-- Content -->

      <div style="padding: 50px 40px">
        <h2 style="margin: 0 0 20px; color: white; font-size: 28px">
          Verify Your Email Address
        </h2>

        <p style="color: #cbd5e1; font-size: 15px; line-height: 1.8">
          Hello
          <strong style="color: #60a5fa"> <%= name %> </strong>,
        </p>

        <p style="color: #94a3b8; font-size: 15px; line-height: 1.8">
          Welcome to AI Career Platform. You're one step away from accessing
          AI-powered interview preparation, coding challenges, career guidance,
          resume reviews and more.
        </p>

        <p style="color: #94a3b8; font-size: 15px; line-height: 1.8">
          Please verify your email address by clicking the button below.
        </p>

        <!-- CTA -->

        <div style="text-align: center; margin: 40px 0">
          <a
            href="<%= link %>"
            style="
              display: inline-block;
              background: linear-gradient(135deg, #2563eb, #3b82f6);
              color: white;
              text-decoration: none;
              padding: 16px 40px;
              border-radius: 12px;
              font-size: 16px;
              font-weight: 600;
            "
          >
            Verify Email Address
          </a>
        </div>

        <!-- Link Box -->

        <div
          style="
            background: #111827;
            border: 1px solid #1e293b;
            border-radius: 12px;
            padding: 16px;
            word-break: break-all;
            color: #94a3b8;
            font-size: 13px;
          "
        >
          <%= link %>
        </div>

        <p
          style="
            margin-top: 25px;
            color: #64748b;
            font-size: 14px;
            line-height: 1.8;
          "
        >
          If you did not create an account, you can safely ignore this email.
        </p>
      </div>

      <!-- Footer -->

      <div
        style="
          background: #020617;
          border-top: 1px solid #1e293b;
          text-align: center;
          padding: 25px;
        "
      >
        <p style="margin: 0; color: #64748b; font-size: 13px">
          © <%= year %> AI Career Platform
        </p>

        <p style="margin-top: 10px; color: #475569; font-size: 12px">
          Powered by AI • Career Growth • Interview Success
        </p>
      </div>
    </div>
  </body>
</html>
